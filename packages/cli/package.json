{
  "name": "ondajs",
  "version": "0.4.1",
  "description": "Install Onda motion-graphics components into your Remotion project. Source you own, motion identity built in, agent-friendly contract.",
  "license": "MIT",
  "author": {
    "name": "Rodrigo Botelho",
    "url": "https://github.com/degueba"
  },
  "type": "module",
  "main": "./dist/manifest.js",
  "types": "./dist/manifest.d.ts",
  "exports": {
    ".": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    },
    "./manifest": {
      "types": "./dist/manifest.d.ts",
      "import": "./dist/manifest.js"
    }
  },
  "bin": {
    "ondajs": "./dist/onda.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "homepage": "https://onda.video",
  "repository": {
    "type": "git",
    "url": "https://github.com/degueba/onda.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/degueba/onda/issues"
  },
  "keywords": [
    "remotion",
    "motion-graphics",
    "video",
    "react",
    "typescript",
    "cli",
    "registry",
    "components",
    "shadcn",
    "ai",
    "agent",
    "animation",
    "onda"
  ],
  "scripts": {
    "sync-manifest": "node ../../scripts/sync-manifest-module.mjs",
    "build:cli": "tsc -p tsconfig.json",
    "build:manifest": "pnpm sync-manifest && node build-manifest.mjs",
    "build": "pnpm build:cli && pnpm build:manifest",
    "prepublishOnly": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "peerDependencies": {
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.4.0"
  }
}
